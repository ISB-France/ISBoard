# ── Django ──
DEBUG=False
DJANGO_SECRET_KEY=changez-moi-par-une-cle-securisee
ALLOWED_HOSTS=monapp.com,www.monapp.com,localhost

# ── Base de données ──
DB_NAME=isboard
DB_USER=isboard
DB_PASSWORD=changez-moi
DB_HOST=db
DB_PORT=5432

# ── URLs ──
FRONTEND_URL=https://monapp.com
CORS_ALLOWED_ORIGINS=https://monapp.com

# ── OIDC (Microsoft Entra ID) ──
OIDC_CLIENT_ID=votre-client-id
OIDC_CLIENT_SECRET=votre-client-secret
OIDC_OP_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/oauth2/v2.0/authorize
OIDC_OP_TOKEN_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/oauth2/v2.0/token
OIDC_OP_JWKS_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/discovery/v2.0/keys
OIDC_REDIRECT_URI=https://monapp.com/api/auth/callback

# ── Admin auto-créé ──
ADMIN_EMAIL=admin@monapp.com
ADMIN_PASSWORD=changez-moi
