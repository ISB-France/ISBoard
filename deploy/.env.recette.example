# ── Django ──
DEBUG=True
DJANGO_SECRET_KEY=changez-moi-aussi
ALLOWED_HOSTS=recette.monapp.com,localhost

# ── Base de données ──
DB_NAME=isboard_recette
DB_USER=isboard
DB_PASSWORD=changez-moi
DB_HOST=db
DB_PORT=5432

# ── URLs ──
FRONTEND_URL=https://recette.monapp.com
CORS_ALLOWED_ORIGINS=https://recette.monapp.com

# ── OIDC (Microsoft Entra ID) ──
OIDC_CLIENT_ID=votre-client-id-recette
OIDC_CLIENT_SECRET=votre-client-secret-recette
OIDC_OP_AUTHORIZATION_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/oauth2/v2.0/authorize
OIDC_OP_TOKEN_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/oauth2/v2.0/token
OIDC_OP_JWKS_ENDPOINT=https://login.microsoftonline.com/<TENANT_ID>/discovery/v2.0/keys
OIDC_REDIRECT_URI=https://recette.monapp.com/api/auth/callback

# ── Admin auto-créé ──
ADMIN_EMAIL=admin@monapp.com
ADMIN_PASSWORD=changez-moi
